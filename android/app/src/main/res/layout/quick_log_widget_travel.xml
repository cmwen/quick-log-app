<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/quick_log_widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_log_travel_widget_title"
            android:textColor="@color/widget_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Ready to log"
            android:textColor="@color/widget_muted_text"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_content_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Log current location"
        android:textColor="@color/widget_on_surface"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_content_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:text="Open Quick Log to save where you are right now."
        android:textColor="@color/widget_muted_text"
        android:textSize="12sp" />

    <Button
        android:id="@+id/widget_primary_action"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/quick_log_widget_primary_button_background"
        android:paddingHorizontal="12dp"
        android:text="@string/quick_log_widget_primary_travel"
        android:textAllCaps="false"
        android:textColor="@color/widget_on_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/widget_secondary_action"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/quick_log_widget_secondary_button_background"
        android:paddingHorizontal="12dp"
        android:text="@string/quick_log_widget_secondary_entries"
        android:textAllCaps="false"
        android:textColor="@color/widget_on_secondary_surface"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
