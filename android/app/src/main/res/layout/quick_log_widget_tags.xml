<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/quick_log_widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_log_tags_widget_title"
            android:textColor="@color/widget_on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Ready to log"
            android:textColor="@color/widget_muted_text"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_content_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Start your first log"
        android:textColor="@color/widget_on_surface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_content_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Open Quick Log to choose tags and save your first entry."
        android:textColor="@color/widget_muted_text"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_shortcut_1"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/quick_log_widget_chip_background"
            android:paddingHorizontal="12dp"
            android:text="Work"
            android:textAllCaps="false"
            android:textColor="@color/widget_on_chip_surface"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/widget_shortcut_2"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/quick_log_widget_chip_background"
            android:paddingHorizontal="12dp"
            android:text="Gym"
            android:textAllCaps="false"
            android:textColor="@color/widget_on_chip_surface"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/widget_shortcut_3"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/quick_log_widget_chip_background"
            android:paddingHorizontal="12dp"
            android:text="Home"
            android:textAllCaps="false"
            android:textColor="@color/widget_on_chip_surface"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_primary_action"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/quick_log_widget_primary_button_background"
            android:paddingHorizontal="12dp"
            android:text="@string/quick_log_widget_primary_entry"
            android:textAllCaps="false"
            android:textColor="@color/widget_on_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/widget_secondary_action"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/quick_log_widget_secondary_button_background"
            android:paddingHorizontal="12dp"
            android:text="@string/quick_log_widget_secondary_entries"
            android:textAllCaps="false"
            android:textColor="@color/widget_on_secondary_surface"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
