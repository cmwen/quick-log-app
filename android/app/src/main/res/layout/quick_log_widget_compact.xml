<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/quick_log_widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Ready to log"
            android:textColor="@color/widget_muted_text"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/widget_primary_action"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/quick_log_widget_primary_button_background"
        android:paddingHorizontal="12dp"
        android:text="Log here"
        android:textAllCaps="false"
        android:textColor="@color/widget_on_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/widget_secondary_action"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/quick_log_widget_secondary_button_background"
        android:paddingHorizontal="12dp"
        android:text="Entries"
        android:textAllCaps="false"
        android:textColor="@color/widget_on_secondary_surface"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
