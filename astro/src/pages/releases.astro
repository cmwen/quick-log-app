---
import BaseLayout from '../layouts/BaseLayout.astro'

const baseUrlRaw = import.meta.env.BASE_URL;
const baseUrl = baseUrlRaw.endsWith('/') ? baseUrlRaw : `${baseUrlRaw}/`;
const obtainiumUrl = 'https://apps.obtainium.page/redirect?r=obtainium%3A%2F%2Fadd%2Fhttps%253A%252F%252Fgithub.com%252Fcmwen%252Fquick-log-app';
---

<BaseLayout title="Releases">
  <section>
    <h2>Releases & Downloads</h2>

    <div class="card">
      <p class="lead">When releases are published, you can download Android artifacts from GitHub Releases.</p>
      <div class="cta-row">
        <a class="button primary" href="https://github.com/cmwen/quick-log-app/releases/latest" target="_blank" rel="noopener">Open latest release</a>
        <a class="button" href={obtainiumUrl} target="_blank" rel="noopener">Add to Obtainium</a>
        <a class="button" href={`${baseUrl}web-usb-install/`}>Try WebUSB install</a>
      </div>
    </div>

    <div class="card">
      <h3>If you built from source</h3>
      <ul>
        <li>Android APK: <code>flutter build apk --release</code></li>
        <li>Android App Bundle (Play Store): <code>flutter build appbundle --release</code></li>
      </ul>
    </div>

    <div class="card">
      <h3>Release workflow</h3>
      <p class="lead">This repository includes CI workflows for building and publishing releases, including signed artifacts when secrets are configured.</p>
      <p><a href="https://github.com/cmwen/quick-log-app/blob/main/GETTING_STARTED.md" target="_blank" rel="noopener" style="color:var(--accent);text-decoration:none">See setup guide →</a></p>
    </div>
  </section>
</BaseLayout>
